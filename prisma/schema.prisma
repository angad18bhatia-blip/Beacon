generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth.js (NextAuth) required models ---
// https://authjs.dev/getting-started/adapters/prisma

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Student profile (filled in during onboarding)
  school       String?
  degreeLevel  String?
  areaOfStudy  String?
  bio          String?
  onboarded    Boolean  @default(false)

  // Simple daily send-rate limiting
  sendCount     Int      @default(0)
  sendCountDate DateTime?

  // Daily rate limit for the AI prompt generator (free API, but still
  // rate-limited/shared, so worth capping)
  promptGenCount     Int      @default(0)
  promptGenCountDate DateTime?

  // Daily rate limit for AI-grounded drafting, separate from the prompt
  // generator's budget above since it's a per-professor action a student
  // may reasonably want to use more than a few times a day
  aiDraftCount     Int      @default(0)
  aiDraftCountDate DateTime?

  accounts   Account[]
  sessions   Session[]
  professors Professor[]
  templates  EmailTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProfessorStatus {
  NEW
  DRAFTED
  APPROVED
  SENT
}

model Professor {
  id             String          @id @default(cuid())
  userId         String
  name           String
  email          String
  school         String
  department     String?
  researchArea   String?
  notes          String?
  status         ProfessorStatus @default(NEW)
  draftSubject   String?
  draftBody      String?
  sentAt         DateTime?
  gmailMessageId String?

  // Gmail thread bookkeeping for reply detection
  threadId     String?
  hasReply     Boolean   @default(false)
  replySnippet String?
  repliedAt    DateTime?

  // Which saved template produced the current draft, snapshotted by name
  // at generation time (for the stats page — survives template edits/deletes)
  templateNameUsed String?

  // "manual" (student-entered) or "database" (imported from the
  // pre-built ResearcherDatabase)
  source           String  @default("manual")
  importedFromDbId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String  @id @default(cuid())
  userId    String
  name      String  @default("Default")
  subject   String
  body      String
  isDefault Boolean @default(true)
  source    String  @default("manual") // "manual" or "ai_generated"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pre-built, shared (not per-user) database of verified researchers —
// populated offline by scripts/build-researcher-db.ts, searched for free
// at request time by the Discover feature so there's no live-query
// hallucination risk and no per-search API cost.
model ResearcherDatabase {
  id                  String   @id @default(cuid())
  name                String
  university          String
  college              String?
  department           String
  title                String?
  fieldOfResearch      String?
  researchSummary      String?
  recentProjects       String?
  email                String?
  facultyWebsite       String?
  labWebsite           String?
  verificationSources  String? // newline-separated source URLs

  // Fit for a high-school student reaching out — carried over from manual
  // research rather than computed by this app
  highSchoolFriendliness String?
  undergradMentoring     String?
  outreachScore          Int? // 1-10, higher = better fit
  responseProbability    String? // e.g. "High" / "Medium" / "Low"
  notes                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([university, department])
}
