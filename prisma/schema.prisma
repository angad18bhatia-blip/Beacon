generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Auth.js (NextAuth) required models ---
// https://authjs.dev/getting-started/adapters/prisma

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Student profile (filled in during onboarding)
  school       String?
  degreeLevel  String?
  areaOfStudy  String?
  bio          String?
  onboarded    Boolean  @default(false)

  // Simple daily send-rate limiting
  sendCount     Int      @default(0)
  sendCountDate DateTime?

  accounts   Account[]
  sessions   Session[]
  professors Professor[]
  templates  EmailTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProfessorStatus {
  NEW
  DRAFTED
  APPROVED
  SENT
}

model Professor {
  id             String          @id @default(cuid())
  userId         String
  name           String
  email          String
  school         String
  department     String?
  researchArea   String?
  notes          String?
  status         ProfessorStatus @default(NEW)
  draftSubject   String?
  draftBody      String?
  sentAt         DateTime?
  gmailMessageId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String  @id @default(cuid())
  userId    String
  name      String  @default("Default")
  subject   String
  body      String
  isDefault Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
